// Conadis admin · Prisma schema
// Postgres + RBAC (User ↔ Role ↔ Permission) + sessions

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  name         String
  passwordHash String
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tipoDocumento   TipoDocumento?
  numeroDocumento String?

  roles    UserRole[]
  sessions Session[]

  socioAccount    Socio?           @relation("SocioUser")
  sociosCreated   Socio[]          @relation("SocioCreatedBy")
  sociosUpdated   Socio[]          @relation("SocioUpdatedBy")
  socioAdjuntos   SocioAdjunto[]   @relation("SocioAdjuntoUploader")
  socioEstadoLogs SocioEstadoLog[] @relation("SocioEstadoLogBy")
  solicitudesRevisadas         SolicitudActualizacionDatos[]    @relation("SolicitudRevisadaPor")
  registrosPublicosRevisados   SolicitudRegistroPublico[]       @relation("RegistroPublicoRevisor")

  puestosCreated        Puesto[]           @relation("PuestoCreatedBy")
  puestosUpdated        Puesto[]           @relation("PuestoUpdatedBy")
  puestoAsignaciones    PuestoAsignacion[] @relation("PuestoAsignacionBy")
  asambleasCreated      Asamblea[]         @relation("AsambleaCreatedBy")
  asistenciasReg        Asistencia[]       @relation("AsistenciaBy")
  cuotasPago            Cuota[]            @relation("CuotaPagoBy")
  constanciasEmitidas   Constancia[]       @relation("ConstanciaEmitidoPor")
  comprobantesEmitidos  Comprobante[]      @relation("ComprobanteEmitidoPor")
  transferenciasCreadas Transferencia[]    @relation("TransferenciaCreatedBy")
  transferenciasRenunciaSubidas Transferencia[] @relation("TransferenciaRenunciaUploadedBy")
  transferenciasContratoSubidas Transferencia[] @relation("TransferenciaContratoUploadedBy")
  anunciosCreados       Anuncio[]          @relation("AnuncioCreatedBy")
  anunciosUpdated       Anuncio[]          @relation("AnuncioUpdatedBy")
  movimientosCaja       MovimientoCaja[]   @relation("MovimientoRegistradoPor")
  empleadosCreados      Empleado[]         @relation("EmpleadoCreatedBy")
  empleadosUpdated      Empleado[]         @relation("EmpleadoUpdatedBy")
  empleadoAdjuntos      EmpleadoAdjunto[]  @relation("EmpleadoAdjuntoUploader")
  bienesCreados         Bien[]             @relation("BienCreatedBy")
  bienesUpdated         Bien[]             @relation("BienUpdatedBy")
  movimientosBien       MovimientoBien[]   @relation("MovimientoBienBy")
  directivosReg         Directivo[]        @relation("DirectivoBy")
  renunciasCreadas      Renuncia[]         @relation("RenunciaCreatedBy")

  @@unique([tipoDocumento, numeroDocumento])
  @@index([active])
}

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  system      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?
  category    String

  roles RolePermission[]

  @@index([category])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Session {
  id         String     @id @default(cuid())
  userId     String
  token      String     @unique
  expiresAt  DateTime
  createdAt  DateTime   @default(now())
  userAgent  String?
  ip         String?
  clientType ClientType @default(web)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum ClientType {
  web
  mobile
}

// ─────────────────────────── Padrón de socios ───────────────────────────

enum TipoDocumento {
  DNI
  CE
  PASAPORTE
  RUC
}

enum EstadoSocio {
  activo
  suspendido
  retirado
  fallecido
}

enum Sexo {
  M
  F
}

model Socio {
  id              String        @id @default(cuid())
  codigo          String        @unique
  // Nº de padrón oficial de la asociación (del Excel del padrón). No único a
  // propósito: el padrón fuente trae huecos/ruido; se regulariza luego.
  numeroPadron    Int?
  tipoDocumento   TipoDocumento
  numeroDocumento String
  apellidoPaterno String
  apellidoMaterno String?
  nombres         String
  fechaNacimiento DateTime?
  sexo            Sexo?
  estadoCivil     String?

  telefono     String?
  email        String?
  direccion    String?
  distrito     String?
  provincia    String?
  departamento String?

  fechaIngreso  DateTime
  estado        EstadoSocio @default(activo)
  observaciones String?

  // Saldo a favor (S/) acumulado cuando un pago por monto excede las cuotas
  // pendientes; se consume en el siguiente pago.
  saldoAFavor Decimal @default(0) @db.Decimal(10, 2)

  // Concatenación normalizada (lowercase, sin tildes) de codigo + documento +
  // apellidos + nombres. Permite búsqueda accent-insensitive sin extensiones
  // de Postgres. Se mantiene en createSocio/updateSocio y en el seed.
  searchKey String @default("")

  fotoUrl String?

  userId        String? @unique
  portalEnabled Boolean @default(false)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User?            @relation("SocioUser", fields: [userId], references: [id], onDelete: SetNull)
  createdBy User?            @relation("SocioCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?            @relation("SocioUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  adjuntos  SocioAdjunto[]
  estadoLog SocioEstadoLog[]

  asignacionesPuesto             PuestoAsignacion[]
  asistencias                    Asistencia[]
  cuotas                         Cuota[]
  constancias                    Constancia[]
  comprobantes                   Comprobante[]
  movimientosCaja                MovimientoCaja[]
  transferenciasComoTransferente Transferencia[]    @relation("TransferenteSocio")
  transferenciasComoAdquiriente  Transferencia[]    @relation("AdquirienteSocio")
  directivos                     Directivo[]
  renuncias                      Renuncia[]
  solicitudesActualizacion       SolicitudActualizacionDatos[]
  registrosPublicos              SolicitudRegistroPublico[]     @relation("RegistroPublicoSocio")

  @@unique([tipoDocumento, numeroDocumento])
  @@index([estado])
  @@index([numeroPadron])
  @@index([apellidoPaterno, apellidoMaterno, nombres])
}

model SocioAdjunto {
  id           String   @id @default(cuid())
  socioId      String
  tipo         String
  url          String
  mimeType     String
  sizeBytes    Int?
  uploadedById String?
  createdAt    DateTime @default(now())

  socio      Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("SocioAdjuntoUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([socioId])
}

model SocioEstadoLog {
  id         String      @id @default(cuid())
  socioId    String
  fromEstado EstadoSocio
  toEstado   EstadoSocio
  motivo     String
  byUserId   String?
  createdAt  DateTime    @default(now())

  socio  Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  byUser User? @relation("SocioEstadoLogBy", fields: [byUserId], references: [id], onDelete: SetNull)

  @@index([socioId])
}

enum EstadoSolicitudActualizacion {
  pendiente
  aprobada
  rechazada
}

// Solicitud de actualización de datos hecha por el propio socio desde el portal.
// `datos` es el snapshot JSON de los valores propuestos (solo campos de la
// whitelist del autoservicio). El admin la revisa y al APROBAR se aplica al
// padrón por la misma ruta validada que updateSocio. Un índice parcial único
// (ver migración) garantiza máximo UNA pendiente por socio.
model SolicitudActualizacionDatos {
  id            String                       @id @default(cuid())
  socioId       String
  datos         Json
  estado        EstadoSolicitudActualizacion @default(pendiente)
  motivoRechazo String?
  creadoEn      DateTime                     @default(now())
  revisadoPorId String?
  revisadoEn    DateTime?

  socio       Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  revisadoPor User? @relation("SolicitudRevisadaPor", fields: [revisadoPorId], references: [id], onDelete: SetNull)

  @@index([socioId])
  @@index([estado])
}

// Solicitud de registro hecha por un visitante anónimo desde el portal público.
// Permite que alguien que aún no es socio registrado solicite ser vinculado al
// padrón. Un índice parcial único garantiza máximo UNA pendiente por número de
// documento (ver migración).
model SolicitudRegistroPublico {
  id              String        @id @default(cuid())
  tipoDocumento   TipoDocumento @default(DNI)
  numeroDocumento String
  nombreCompleto  String
  telefono        String
  email           String?
  estado          EstadoSolicitudActualizacion @default(pendiente)
  socioVinculadoId String?
  motivoRechazo   String?
  ip              String?
  creadoEn        DateTime  @default(now())
  revisadoPorId   String?
  revisadoEn      DateTime?

  socioVinculado Socio? @relation("RegistroPublicoSocio", fields: [socioVinculadoId], references: [id], onDelete: SetNull)
  revisadoPor    User?  @relation("RegistroPublicoRevisor", fields: [revisadoPorId], references: [id], onDelete: SetNull)

  @@index([estado])
  @@index([numeroDocumento])
}

// ─────────────────────────── Órganos directivos ───────────────────────────
//
// Modela quién ocupa cargos en los órganos de gobierno de la asociación
// (Consejo Directivo, Fiscalía, comités) y los coordinadores de bloque. Sustituye
// al "presidente" hardcodeado en ORG por datos vivos. Un Directivo vincula un
// Socio con un cargo dentro de un órgano por un periodo (desde/hasta; hasta=null
// = vigente), conservando el historial de juntas directivas y sosteniendo la ruta
// diferenciada de sanciones a directivos (REFASA Art. 7.2, 16.1 y 38).
enum Organo {
  consejo_directivo
  fiscalia
  comite
  coordinacion_bloque
}

enum CargoDirectivo {
  presidente
  vicepresidente
  secretario
  tesorero
  fiscal
  vocal
  coordinador // de bloque
  otro
}

model Directivo {
  id      String         @id @default(cuid())
  socioId String
  organo  Organo
  cargo   CargoDirectivo
  // Bloque que coordina (solo para organo = coordinacion_bloque).
  bloque  String?
  // Etiqueta del periodo de gestión, p. ej. "2025-2027".
  periodo String?

  desde         DateTime  @default(now())
  hasta         DateTime? // null = cargo vigente
  observaciones String?

  // Firma escaneada del directivo (imagen). URL a la ruta protegida
  // /api/uploads/organos/<id>/<file>. Se renderiza en documentos por cargo.
  firmaUrl          String?
  firmaUploadedAt   DateTime?
  firmaUploadedById String?

  byUserId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socio  Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  byUser User? @relation("DirectivoBy", fields: [byUserId], references: [id], onDelete: SetNull)

  @@index([socioId])
  @@index([organo, hasta])
  @@index([cargo, hasta])
}

// ─────────────────────────── Renuncias ───────────────────────────
//
// Expediente de la renuncia voluntaria de un socio. El Estatuto (Art. 8.a) exige
// que la renuncia escrita, dirigida al Presidente, sea ACEPTADA por el Consejo
// Directivo y ratificada por la Asamblea General. Se modela como una máquina de
// estados: solicitada → aceptada_cd → ratificada_ag → efectiva (o rechazada). Al
// quedar efectiva, el socio pasa a 'retirado' (con SocioEstadoLog) y se liberan
// sus puestos. La carta imprimible se respalda en este registro.
enum EstadoRenuncia {
  solicitada
  aceptada_cd
  ratificada_ag
  efectiva
  rechazada
}

model Renuncia {
  id      String @id @default(cuid())
  socioId String

  estado         EstadoRenuncia @default(solicitada)
  motivo         String?
  fechaSolicitud DateTime       @default(now())

  // Acta del Consejo Directivo que ACEPTA la renuncia (Estatuto Art. 8.a).
  actaCdNumero String?
  actaCdFecha  DateTime?
  // Acta de la Asamblea General que RATIFICA la renuncia.
  actaAgNumero String?
  actaAgFecha  DateTime?

  // Cuándo quedó efectiva (socio retirado + puestos liberados).
  efectivaEn    DateTime?
  // Motivo del rechazo, si el órgano no acepta la renuncia.
  motivoRechazo String?
  observaciones String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  socio     Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  createdBy User? @relation("RenunciaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([socioId])
  @@index([estado])
}

// ─────────────────────────── Puestos ───────────────────────────

enum EstadoPuesto {
  activo
  vacio
  clausurado
  construccion
}

enum BandaPuesto {
  alta
  media
  baja
}

enum DimensionPuesto {
  d3x5
  d3x3
}

enum TipoEspacio {
  puesto
  sshh
  almacen
}

enum Giro {
  verduras
  abarrotes
  carnes
  pescados
  comidas
  ropa
  calzado
  ferreteria
  productos_region
  juguetes
  flores_plantas
  otros
}

model Puesto {
  id            String          @id @default(cuid())
  etapa         Int // 1 | 2  (Etapa 1 = puestos 3×5 grandes; Etapa 2 = 3×3 pequeños)
  bloque        String // 'A'..'M'
  fila          Int             @default(1) // sub-fila dentro del bloque (1,2,3)
  numero        Int // número del puesto dentro de su (etapa,bloque,fila)
  banda         BandaPuesto
  dimension     DimensionPuesto
  tipo          TipoEspacio     @default(puesto) // puesto | sshh | almacen
  giro          Giro?
  codigo        String          @unique // derivado 'E1-A-12'
  estado        EstadoPuesto    @default(vacio)
  fotoUrl       String?
  observaciones String?
  searchKey     String          @default("")

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy      User?              @relation("PuestoCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?              @relation("PuestoUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  asignaciones   PuestoAsignacion[]
  transferencias Transferencia[]

  @@unique([etapa, bloque, fila, numero])
  @@index([estado])
  @@index([etapa, bloque])
  @@index([giro])
}

model PuestoAsignacion {
  id        String    @id @default(cuid())
  puestoId  String
  socioId   String
  desde     DateTime  @default(now())
  hasta     DateTime?
  motivo    String?
  byUserId  String?
  createdAt DateTime  @default(now())

  // Restrict (no Cascade): borrar un puesto NO debe arrasar su historial de
  // ocupación. deletePuesto bloquea el borrado si hay asignaciones; esta FK es
  // la última línea de defensa a nivel de BD para preservar la trazabilidad.
  puesto Puesto @relation(fields: [puestoId], references: [id], onDelete: Restrict)
  socio  Socio  @relation(fields: [socioId], references: [id], onDelete: Cascade)
  byUser User?  @relation("PuestoAsignacionBy", fields: [byUserId], references: [id], onDelete: SetNull)

  @@index([puestoId, hasta])
  @@index([socioId, hasta])
}

// ─────────────────────────── Transferencias de puesto ───────────────────────────
//
// Expediente del traspaso de un puesto: del socio TRANSFERENTE al ADQUIRIENTE
// (persona nueva). Guarda los datos del adquiriente para generar el contrato y,
// al FORMALIZAR, dar de alta al adquiriente como socio + mover el puesto +
// retirar al transferente (todo atómico).
enum EstadoTransferencia {
  borrador // datos cargados; aún no formalizada
  completada // formalizada: puesto movido + socio nuevo + transferente retirado
  anulada
}

model Transferencia {
  id     String @id @default(cuid())
  codigo String @unique // "TR-2026-0001"

  transferenteId String
  puestoId       String

  // Datos del adquiriente (nuevo dueño). Snapshot al crear; al formalizar se
  // usan para dar de alta al socio nuevo y para el contrato.
  adqTipoDocumento   TipoDocumento @default(DNI)
  adqNumeroDocumento String
  adqApellidoPaterno String
  adqApellidoMaterno String?
  adqNombres         String
  adqEstadoCivil     String?
  adqDireccion       String?
  adqDistrito        String?
  adqProvincia       String?
  adqDepartamento    String?
  adqTelefono        String?

  monto  Decimal?            @db.Decimal(10, 2) // precio de venta (interno, no va en el contrato)
  fecha  DateTime // fecha del contrato
  estado EstadoTransferencia @default(borrador)

  adquirienteSocioId String? // socio creado al formalizar
  completadaEn       DateTime?

  // Escaneos firmados que respaldan la formalización (ambos requeridos para
  // poder formalizar): se suben a /api/uploads/transferencias/<id>/<file>.
  renunciaUrl String? // carta de renuncia firmada
  contratoUrl String? // contrato de transferencia firmado
  // Auditoría: quién y cuándo subió cada escaneo.
  renunciaUploadedById String?
  renunciaUploadedAt   DateTime?
  contratoUploadedById String?
  contratoUploadedAt   DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transferente     Socio  @relation("TransferenteSocio", fields: [transferenteId], references: [id], onDelete: Cascade)
  puesto           Puesto @relation(fields: [puestoId], references: [id], onDelete: Cascade)
  adquirienteSocio Socio? @relation("AdquirienteSocio", fields: [adquirienteSocioId], references: [id], onDelete: SetNull)
  createdBy        User?  @relation("TransferenciaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  renunciaUploadedBy User? @relation("TransferenciaRenunciaUploadedBy", fields: [renunciaUploadedById], references: [id], onDelete: SetNull)
  contratoUploadedBy User? @relation("TransferenciaContratoUploadedBy", fields: [contratoUploadedById], references: [id], onDelete: SetNull)

  @@index([transferenteId])
  @@index([puestoId])
  @@index([estado])
  @@index([createdAt])
}

// ─────────────────────────── Asambleas ───────────────────────────

enum TipoAsamblea {
  ordinaria
  extraordinaria
}

enum EstadoAsamblea {
  programada
  en_curso
  cerrada
}

enum EstadoAsistencia {
  presente
  ausente
  justificado
  tardanza
}

model Asamblea {
  id            String         @id @default(cuid())
  titulo        String
  tipo          TipoAsamblea   @default(ordinaria)
  fecha         DateTime // inicio de la entrada (fecha + hora)
  lugar         String?
  agenda        String?
  estado        EstadoAsamblea @default(programada)
  quorumMinimo  Int?
  toleranciaMin Int            @default(15) // minutos de tolerancia: hasta inicio+tol = presente

  // Multas (S/) que se cargan como deuda al "Aplicar multas": a los socios en
  // tardanza y a los ausentes (sin justificar). null/0 = sin multa de ese tipo.
  multaTardanza     Decimal?  @db.Decimal(10, 2)
  multaInasistencia Decimal?  @db.Decimal(10, 2)
  // Sello de cuándo se aplicaron las multas (para mostrar estado / permitir
  // reaplicar). null = aún no aplicadas.
  multasAplicadasEn DateTime?

  // Código único que viaja en el QR de asistencia: el socio escanea y abre
  // /portal/asambleas/<codigo> para auto-registrarse. No es secreto.
  codigoVerificacion String? @unique

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User?        @relation("AsambleaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  asistencias Asistencia[]

  @@index([fecha])
  @@index([estado])
}

model Asistencia {
  id          String           @id @default(cuid())
  asambleaId  String
  socioId     String
  estado      EstadoAsistencia @default(ausente)
  observacion String?
  byUserId    String?
  updatedAt   DateTime         @updatedAt

  asamblea Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  socio    Socio    @relation(fields: [socioId], references: [id], onDelete: Cascade)
  byUser   User?    @relation("AsistenciaBy", fields: [byUserId], references: [id], onDelete: SetNull)

  @@unique([asambleaId, socioId])
  @@index([asambleaId])
  @@index([socioId])
}

// ─────────────────────────── Cuotas / aportes ───────────────────────────

enum EstadoCuota {
  pendiente
  pagada
  anulada
}

model Cuota {
  id           String      @id @default(cuid())
  socioId      String
  periodo      String // "2026-05"
  concepto     String
  monto        Decimal     @db.Decimal(10, 2)
  vencimiento  DateTime?
  estado       EstadoCuota @default(pendiente)
  pagadoEn     DateTime?
  pagadoMonto  Decimal?    @db.Decimal(10, 2)
  metodoPago   String?
  // N.° de operación / recibo registrado al pagar. Obligatorio para el autovalúo:
  // un índice único parcial (ver migración) impide reusar el mismo N.° en otra
  // cuota de autovalúo (concepto ILIKE '%autoval%'), evitando que un recibo se
  // use para "pagar" el autovalúo de otro año.
  nroOperacion String?
  byUserId     String?
  createdById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  socio  Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  byUser User? @relation("CuotaPagoBy", fields: [byUserId], references: [id], onDelete: SetNull)

  @@unique([socioId, periodo, concepto])
  @@index([socioId, estado])
  @@index([periodo])
  @@index([estado])
}

// ─────────────────────────── Constancias emitidas ───────────────────────────
//
// Cada vez que se emite una constancia (de socio hábil o de no adeudo) se
// registra aquí. El registro es la "fuente de verdad" que respalda la
// verificación pública por QR/código: aunque el socio cambie o se elimine
// después, el documento emitido sigue siendo verificable gracias al snapshot.
enum TipoConstancia {
  socio_habil
  no_adeudo
}

model Constancia {
  id String @id @default(cuid())

  // Tipo de constancia: socio hábil o constancia de no adeudo.
  tipo TipoConstancia @default(socio_habil)

  // Folio correlativo legible para registro/seguimiento ("000123-2026").
  folio String @unique

  // Código de verificación que viaja en el QR y se valida en
  // /verificar/<codigo>. Aleatorio para que no se pueda adivinar.
  codigo String @unique

  // Snapshot al momento de emisión (la verificación muestra lo que decía el
  // documento, no el estado actual del socio).
  socioId         String?
  socioCodigo     String
  socioNombre     String
  tipoDocumento   String
  numeroDocumento String
  estadoSnapshot  String

  habil       Boolean   @default(true)
  emitidoEn   DateTime  @default(now())
  validoHasta DateTime?
  anulada     Boolean   @default(false)

  emitidoPorId String?

  socio      Socio? @relation(fields: [socioId], references: [id], onDelete: SetNull)
  emitidoPor User?  @relation("ConstanciaEmitidoPor", fields: [emitidoPorId], references: [id], onDelete: SetNull)

  @@index([socioId])
  @@index([emitidoEn])
}

// ─────────────────────────── Comprobantes de pago ───────────────────────────
//
// Recibo emitido cuando un socio paga cuotas/deudas. Mismo patrón que la
// Constancia: folio correlativo + código verificable por QR en
// /comprobantes/verificar/<codigo>, con snapshot de los datos al momento del
// pago (sigue siendo verificable aunque el socio o la cuota cambien después).
// 1:1 con el MovimientoCaja del ingreso registrado.
model Comprobante {
  id String @id @default(cuid())

  folio  String @unique // "000123-2026"
  codigo String @unique // "CP-2026-XXXX-XXXX"

  // Snapshot del pago al momento de emitir.
  socioId         String?
  socioCodigo     String
  socioNombre     String
  numeroDocumento String
  monto           Decimal @db.Decimal(10, 2)
  metodoPago      String?
  nroOperacion    String?
  detalle         String // qué se pagó (conceptos/periodos), texto

  movimientoCajaId String? @unique

  emitidoEn    DateTime @default(now())
  anulada      Boolean  @default(false)
  emitidoPorId String?

  socio          Socio?          @relation(fields: [socioId], references: [id], onDelete: SetNull)
  movimientoCaja MovimientoCaja? @relation(fields: [movimientoCajaId], references: [id], onDelete: SetNull)
  emitidoPor     User?           @relation("ComprobanteEmitidoPor", fields: [emitidoPorId], references: [id], onDelete: SetNull)

  @@index([socioId])
  @@index([emitidoEn])
}

// ─────────────────────────── Anuncios / Comunicados ───────────────────────────
//
// Publicaciones para mantener informados a los socios. Un mismo modelo cubre
// anuncios y comunicados (campo `tipo`). `visibilidad` decide dónde se ven:
// `publico` aparece en el landing; `socios` solo en el portal del socio.
enum TipoAnuncio {
  anuncio
  comunicado
}

enum VisibilidadAnuncio {
  publico
  socios
}

enum EstadoAnuncio {
  borrador
  publicado
  archivado
}

model Anuncio {
  id          String             @id @default(cuid())
  titulo      String
  resumen     String? // texto corto para tarjetas
  contenido   String // cuerpo completo
  tipo        TipoAnuncio        @default(anuncio)
  visibilidad VisibilidadAnuncio @default(publico)
  estado      EstadoAnuncio      @default(borrador)
  fijado      Boolean            @default(false) // destacar arriba
  imagenUrl   String?
  publicadoEn DateTime?
  validoHasta DateTime?
  searchKey   String             @default("")

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("AnuncioCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("AnuncioUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([estado])
  @@index([visibilidad, estado])
  @@index([publicadoEn])
}

// ─────────────────────────── Caja / Contabilidad ───────────────────────────
//
// Libro de caja de la asociación: cada ingreso o egreso es un MovimientoCaja.
// Cubre cuotas, inscripciones, SS-HH, multas (ingresos) y personal, compras,
// servicios, etc. (egresos), con comprobante (boleta/factura) opcional adjunto.
enum TipoMovimiento {
  ingreso
  egreso
}

enum CategoriaMovimiento {
  // Ingresos
  cuota
  inscripcion
  bano
  multa
  alquiler
  otro_ingreso
  // Egresos
  personal
  compra
  servicio
  mantenimiento
  evento
  servicios_basicos
  otro_egreso
}

enum TipoComprobante {
  ninguno
  boleta
  factura
  recibo
}

model MovimientoCaja {
  id           String              @id @default(cuid())
  tipo         TipoMovimiento
  categoria    CategoriaMovimiento
  monto        Decimal             @db.Decimal(10, 2)
  fecha        DateTime            @default(now())
  concepto     String
  metodoPago   String? // efectivo | transferencia | yape/plin | otro
  // Nº de operación bancaria / código Yape-Plin / nº de depósito (si aplica).
  nroOperacion String?

  // Comprobante (boleta/factura/recibo) opcional, con archivo adjunto.
  comprobanteTipo   TipoComprobante @default(ninguno)
  comprobanteNumero String?
  comprobanteUrl    String?

  // Vínculo opcional con un socio (multa, inscripción, cuota…).
  socioId String?
  origen  String  @default("manual") // manual | cuota (Fase 2)

  registradoPorId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  searchKey       String   @default("")

  socio         Socio?       @relation(fields: [socioId], references: [id], onDelete: SetNull)
  registradoPor User?        @relation("MovimientoRegistradoPor", fields: [registradoPorId], references: [id], onDelete: SetNull)
  comprobante   Comprobante?

  @@index([tipo])
  @@index([categoria])
  @@index([fecha])
  @@index([socioId])
}

// ─────────────────────────── Personal / Empleados ───────────────────────────
//
// Personas contratadas que laboran en el mercado (seguridad, secretaría,
// limpieza, atención de SS-HH, etc.). Se registra desde cuándo laboran
// (fechaIngreso) y se adjunta su CV/contrato. El cese se modela con estado
// "inactivo" + fechaCese (no se borra, para conservar el historial laboral).
enum EstadoEmpleado {
  activo
  suspendido
  inactivo // cesado / ya no labora
}

enum CargoEmpleado {
  seguridad
  secretaria
  limpieza
  bano // atención de servicios higiénicos
  administracion
  mantenimiento
  cobranza
  otro
}

model Empleado {
  id              String        @id @default(cuid())
  codigo          String        @unique // EMP-000001
  tipoDocumento   TipoDocumento
  numeroDocumento String
  apellidoPaterno String
  apellidoMaterno String?
  nombres         String
  cargo           CargoEmpleado @default(otro)
  cargoDetalle    String? // descripción libre, útil cuando cargo = otro

  telefono  String?
  email     String?
  direccion String?

  // Fechas de CALENDARIO (medianoche UTC): desde cuándo labora y, si cesó, cuándo.
  fechaIngreso DateTime
  fechaCese    DateTime?

  estado        EstadoEmpleado @default(activo)
  salario       Decimal?       @db.Decimal(10, 2) // sueldo mensual referencial
  observaciones String?

  // Concatenación normalizada (lowercase, sin tildes) para búsqueda.
  searchKey String  @default("")
  fotoUrl   String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?             @relation("EmpleadoCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?             @relation("EmpleadoUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  adjuntos  EmpleadoAdjunto[]

  @@unique([tipoDocumento, numeroDocumento])
  @@index([estado])
  @@index([cargo])
  @@index([apellidoPaterno, apellidoMaterno, nombres])
}

model EmpleadoAdjunto {
  id           String   @id @default(cuid())
  empleadoId   String
  tipo         String // cv | contrato | dni | foto | otro
  url          String
  mimeType     String
  sizeBytes    Int?
  uploadedById String?
  createdAt    DateTime @default(now())

  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation("EmpleadoAdjuntoUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([empleadoId])
}

// ─────────────────────────── Inventario / Bienes ───────────────────────────
//
// Inventario de bienes/activos físicos del mercado (oficina y almacén). Cada
// bien lleva su stock (cantidad) y un kardex de movimientos (entrada/salida/
// ajuste) que mantiene la cantidad sincronizada y deja trazabilidad.
enum UbicacionBien {
  oficina
  almacen
}

enum EstadoBien {
  nuevo
  conservado
  en_uso
  sin_usar
  desuso
  mal_estado
  roto
  baja
}

enum TipoMovBien {
  entrada
  salida
  ajuste
}

model Bien {
  id            String        @id @default(cuid())
  codigo        String        @unique // correlativo INV-000001
  nombre        String
  ubicacion     UbicacionBien @default(almacen)
  unidad        String        @default("UND") // UND, PQT, CJA, GLN, ROLLO…
  marcaModelo   String?
  cantidad      Int           @default(0) // stock actual (se ajusta vía movimientos)
  estado        EstadoBien    @default(conservado)
  observaciones String?
  searchKey     String        @default("")

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User?            @relation("BienCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?            @relation("BienUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  movimientos MovimientoBien[]

  @@index([ubicacion])
  @@index([estado])
  @@index([nombre])
}

model MovimientoBien {
  id               String      @id @default(cuid())
  bienId           String
  tipo             TipoMovBien
  cantidad         Int // magnitud del movimiento (entrada/salida) o total fijado (ajuste)
  cantidadAnterior Int
  cantidadNueva    Int
  motivo           String?
  byUserId         String?
  createdAt        DateTime    @default(now())

  bien   Bien  @relation(fields: [bienId], references: [id], onDelete: Cascade)
  byUser User? @relation("MovimientoBienBy", fields: [byUserId], references: [id], onDelete: SetNull)

  @@index([bienId, createdAt])
}

// ─────────────────────────── Idempotencia de pagos ───────────────────────────
//
// Clave de idempotencia para el pago por monto (pagarPorMonto): evita que un
// doble-submit acredite dos veces el saldo a favor. El cliente genera un UUID por
// apertura del modal de pago y la acción lo inserta DENTRO de la misma
// transacción del pago; una segunda llamada con la misma clave choca con el @id
// (PK) y se rechaza sin re-aplicar. Si el pago falla por otra causa, la fila se
// revierte con la tx y un reintento legítimo con la misma clave funciona.
model PagoIdempotencia {
  key       String   @id
  socioId   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
