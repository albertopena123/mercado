# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Local file storage for socio adjuntos (served via auth API route)
/private-uploads/socios/*
!/private-uploads/socios/.gitkeep

# Local file storage for anuncios (served via public API route)
/private-uploads/anuncios/*
!/private-uploads/anuncios/.gitkeep

# Local file storage for comprobantes de caja (served via auth API route)
/private-uploads/caja/*
!/private-uploads/caja/.gitkeep

# Local file storage for documentos del personal (served via auth API route)
/private-uploads/empleados/*
!/private-uploads/empleados/.gitkeep

# Local file storage for escaneos firmados de transferencias (served via auth API route)
/private-uploads/transferencias/*
!/private-uploads/transferencias/.gitkeep

# Local file storage for firmas de directivos (served via auth API route)
/private-uploads/organos/*
!/private-uploads/organos/.gitkeep

# Playwright MCP scratch (browser snapshots + console logs from agent sessions)
/.playwright-mcp/

# Agent screenshot scratch
/socios-*.png
/drawer-*.png
/historial.png
/create-modal.png
/search-*.png

# Audit working notes (not committed)
/.audit-findings.md

# Padrón / scratch exportado del Excel + scripts scratch (pueden contener DNIs — no commitear)
/prisma/_*

# Scratch temporal de sesiones de agente (extractos de PDF, diagnósticos, etc.)
/tmp_*
